# Junction Core OS — kernel config fragment (PREEMPT_RT-oriented base + I/O policy)
# Merge into your defconfig or use:
#   ./scripts/kconfig/merge_config.sh arch/arm64/configs/defconfig ../path/to/kernel_rt.config
#
# Goal: trim wireless/BT/HDMI-audio where possible; keep bonding + IEEE 1588 PTP.

# --- Real-time / low latency (enable full RT patchset if you use linux-rt source) ---
# Prefer your arch defconfig first; uncomment one of:
# CONFIG_PREEMPT=y
# CONFIG_PREEMPT_RT=y

# --- Disable Bluetooth (save IRQ / CPU) ---
CONFIG_BT=n
CONFIG_BT_BREDR=n
CONFIG_BT_LE=n
CONFIG_BT_HCIBTUSB=n
CONFIG_BT_HCIUART=n
CONFIG_BT_HCIBTSDIO=n
CONFIG_BT_MTKUART=n
CONFIG_BT_INTEL=n
CONFIG_BT_BCM=n
CONFIG_BT_RTL=n
CONFIG_BT_QCA=n

# --- Disable WiFi / generic WLAN ---
CONFIG_CFG80211=n
CONFIG_MAC80211=n
CONFIG_WLAN=n
CONFIG_WLAN_VENDOR_ADMTEK=n
CONFIG_WLAN_VENDOR_ATH=n
CONFIG_WLAN_VENDOR_ATMEL=n
CONFIG_WLAN_VENDOR_BROADCOM=n
CONFIG_WLAN_VENDOR_CISCO=n
CONFIG_WLAN_VENDOR_INTEL=n
CONFIG_WLAN_VENDOR_INTERSIL=n
CONFIG_WLAN_VENDOR_MARVELL=n
CONFIG_WLAN_VENDOR_MEDIATEK=n
CONFIG_WLAN_VENDOR_MICROCHIP=n
CONFIG_WLAN_VENDOR_RALINK=n
CONFIG_WLAN_VENDOR_REALTEK=n
CONFIG_WLAN_VENDOR_RSI=n
CONFIG_WLAN_VENDOR_ST=n
CONFIG_WLAN_VENDOR_TI=n
CONFIG_WLAN_VENDOR_ZYDAS=n

# --- Reduce HDMI / display audio (platform-specific; disable common HDMI PCM paths) ---
CONFIG_SND_HDA_CORE=n
CONFIG_SND_HDA_CODEC_HDMI=n
CONFIG_SND_SOC_HDMI_CODEC=n
CONFIG_SND_USB_AUDIO=n
# Keep a minimal ALSA path only if you need local beeps; otherwise leave SOC as needed for your board.

# --- Bonding (802.3ad LACP) ---
CONFIG_BONDING=m
CONFIG_NET_CORE=y

# --- PTP / IEEE 1588 ---
CONFIG_NETWORK_PHY_TIMESTAMPING=y
CONFIG_PTP_1588_CLOCK=y
CONFIG_PTP_1588_CLOCK_OPTIONAL=y
# Vendor NIC PTP (enable the block that matches your hardware, e.g.):
# CONFIG_IXGBE_PTP is x86 Intel; for ARM SoC use the stmmac/dwmac PTP options if present:
CONFIG_PTP_1588_CLOCK_KVM=n

# --- Staging / debug noise off in production ---
CONFIG_DEBUG_KERNEL=n
