# =========================
# Junction Dashboard Env
# Copy this file to:
#   .env.local   (for local/dev)
#   .env         (for deployment)
# =========================

# --- Brand logo (PNG in public/, served at /brand/logo.png) ---
# Optional override path:
# NEXT_PUBLIC_BRAND_LOGO=/brand/logo.png
# If the file is missing, the built-in SVG mark is shown instead.
# Set to 1 when your PNG already includes the wordmark:
# NEXT_PUBLIC_BRAND_LOGO_HIDE_WORDMARK=1

# --- Login IP allowlist (see data/server-config.json allowedLoginCidrs) ---
# While running `next dev`, CIDR checks are skipped unless you set:
# JUNCTION_STRICT_LOGIN_IP=1
# Production / `next start` always enforces allowedLoginCidrs (add 127.0.0.0/8 for local browser, or your /32).

# --- Remote operators (laptop / phone over internet) ---
# 1) In Server control: set remoteAccessMode to secure_remote (optional but explicit).
# 2) Add each operator public IP (or VPN egress) to allowedLoginCidrs, or use 0.0.0.0/0 only if you accept the risk.
# 3) Set requireRemoteCode true in server config + set a strong shared secret here (operators enter it on login).
# DASHBOARD_REMOTE_ACCESS_CODE=your-long-shared-secret

# --- Remote access WITHOUT VPS or VPN (tunnel or port-forward) ---
# Cloudflare Tunnel: Terminal A → npm run build && npm run start:public
#                   Terminal B → npm run tunnel:cf  (needs cloudflared installed; see scripts/cloudflared-tunnel.sh)
# Then set (so login CIDR sees the real visitor IP through Cloudflare):
# JUNCTION_TRUST_CLOUDFLARE_HEADERS=1
# With tunnels, mobile IPs change often — use allowedLoginCidrs 0.0.0.0/0 ONLY together with
# requireRemoteCode + DASHBOARD_REMOTE_ACCESS_CODE, or lock to known /32s if you can.
#
# Router port-forward: forward WAN:443 (or 3000) to this PC, run npm run start:public, use HTTPS on the edge if possible.
# Do NOT set JUNCTION_TRUST_CLOUDFLARE_HEADERS unless traffic actually comes from Cloudflare.

# --- Core auth/session ---
# Change these in production.
DASHBOARD_SESSION_SECRET=replace-with-long-random-secret
DASHBOARD_ADMIN_PASSWORD=replace-admin-password
DASHBOARD_PRODUCTION_PASSWORD=replace-production-password
DASHBOARD_VIEWER_PASSWORD=replace-viewer-password

# --- Node agent secure key ---
# Must match on dashboard + all node agents.
JUNCTION_AGENT_KEY=replace-agent-shared-secret

# --- Optional cluster remap gRPC target ---
# Example: 10.0.0.20:50051
CLUSTER_GRPC_ADDR=

# --- Notification channels (optional) ---
# Slack incoming webhook URL
SLACK_WEBHOOK_URL=

# Telegram bot integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional external websocket endpoint ---
# If empty, app defaults to ws://localhost:9000/ws
NEXT_PUBLIC_VISION_WS_URL=

# --- Broadcast media plane ---
# When junction-output-router runs on the same host (see services/output-router/README.md):
# OUTPUT_ROUTER_HEALTH_URL=http://127.0.0.1:9020
# READINESS_SKIP_OUTPUT_ROUTER=1   # omit output-router check entirely

# =========================
# Node-Agent Runtime Env
# (set on each node service, not in dashboard app)
# =========================
# JUNCTION_METRICS_ENDPOINT=http://<dashboard-host>:3000/api/node-metrics
# JUNCTION_COMMAND_ENDPOINT=http://<dashboard-host>:3000/api/node-commands
# JUNCTION_AGENT_KEY=replace-agent-shared-secret
# JUNCTION_ENABLE_COMMAND_EXECUTION=false
# JUNCTION_BIND_IFACE=eth0
